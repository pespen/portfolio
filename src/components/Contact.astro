---

---

<section id="contact" class="min-h-screen py-20 flex items-center scroll-mt-24">
  <div class="container mx-auto w-[85%] max-w-7xl">
    <h2 class="text-3xl font-bold text-center mb-4">Contact Me</h2>
    <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">
      Feel free to reach out if you'd like to work together.
    </p>

    <div class="max-w-2xl mx-auto">
      <div class="p-8">
        <!-- Using Formspree as a simple form backend -->
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <div class="mb-6">
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Name"
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-transparent placeholder-gray-500"
            />
          </div>
          <div class="mb-6">
            <input
              type="email"
              id="email"
              name="email"
              placeholder="Email"
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-transparent placeholder-gray-500"
            />
          </div>
          <div class="mb-6">
            <textarea
              id="message"
              name="message"
              placeholder="Message"
              rows="5"
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-transparent placeholder-gray-500"
            ></textarea>
          </div>
          <button
            type="submit"
            class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white font-medium rounded-md transition-colors duration-300"
          >
            Send Message
          </button>
        </form>
        <p class="mt-4 text-sm text-gray-600">
          Or send an email directly to <a
            href="mailto:pederespen@gmail.com"
            class="text-blue-500 hover:underline">pederespen@gmail.com</a
          >
        </p>
      </div>
    </div>
  </div>
</section>
