---
const {
  title,
  description,
  tags,
  image = "",
  liveUrl = "#",
  sourceUrl = "#",
} = Astro.props;
---

<div
  class="bg-white rounded-lg overflow-hidden shadow-md transition-transform hover:-translate-y-1 hover:shadow-lg"
>
  <div class="h-48 bg-gray-200 overflow-hidden">
    {
      image ? (
        <img src={image} alt={title} class="w-full h-full object-cover" />
      ) : (
        <div class="h-full flex items-center justify-center text-gray-500 font-medium">
          Project Image
        </div>
      )
    }
  </div>
  <div class="p-6">
    <h3 class="text-xl font-semibold mb-3">{title}</h3>
    <p class="text-gray-600 mb-4 text-sm leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 mb-5">
      {
        tags.map((tag: string) => (
          <span class="bg-gray-100 text-blue-500 text-xs px-2 py-1 rounded-md font-medium">
            {tag}
          </span>
        ))
      }
    </div>
    <div class="flex gap-4 text-sm font-medium">
      {
        liveUrl && (
          <a
            href={liveUrl}
            class="text-blue-500 hover:text-blue-700"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Live
          </a>
        )
      }
      {
        sourceUrl && (
          <a
            href={sourceUrl}
            class="text-blue-500 hover:text-blue-700"
            target="_blank"
            rel="noopener noreferrer"
          >
            Source Code
          </a>
        )
      }
    </div>
  </div>
</div>
