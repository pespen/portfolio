---
// Particles component for subtle background animation
---

<div class="particles-container">
  <div class="particles"></div>
</div>

<style>
  .particles-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  .particles {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .particles::before,
  .particles::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    background: rgba(100, 149, 237, 0.15);
    animation: float 20s infinite ease-in-out;
  }

  .particles::before {
    width: 1.7vw;
    height: 1.7vw;
    top: 20%;
    left: 15%;
    animation-delay: 0s;
  }

  .particles::after {
    width: 2vw;
    height: 2vw;
    bottom: 30%;
    right: 10%;
    animation-delay: -7s;
    animation-duration: 25s;
  }

  @keyframes float {
    0% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(15px, 10px) scale(1.05);
    }
    50% {
      transform: translate(30px, 20px) scale(1.1);
    }
    75% {
      transform: translate(15px, 10px) scale(1.05);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }
</style>

<script>
  // Dynamically create additional particles
  document.addEventListener("DOMContentLoaded", () => {
    const particles = document.querySelector(".particles");
    if (!particles) return;

    // Create more particles for a dust-like effect
    for (let i = 0; i < 20; i++) {
      createParticle(particles);
    }
  });

  function createParticle(container: Element) {
    const particle = document.createElement("div");

    // Even smaller size for dust-like effect (0.2vw to 0.7vw)
    const size = 0.2 + Math.random() * 0.5;

    // Random position
    const posX = Math.random() * 100;
    const posY = Math.random() * 100;

    // Varied animation duration
    const duration = 10 + Math.random() * 20;

    // Random delay
    const delay = Math.random() * 15;

    // Random opacity (slightly more visible)
    const opacity = 0.1 + Math.random() * 0.15;

    // Random colors (blues to purples)
    const hue = 210 + Math.random() * 60; // 210-270 range (blues to purples)
    const saturation = 70 + Math.random() * 30; // 70-100%
    const lightness = 70 + Math.random() * 20; // 70-90%

    // Apply styles
    particle.style.position = "absolute";
    particle.style.width = `${size}vw`;
    particle.style.height = `${size}vw`;
    particle.style.left = `${posX}%`;
    particle.style.top = `${posY}%`;
    particle.style.borderRadius = "50%";
    particle.style.background = `hsla(${hue}, ${saturation}%, ${lightness}%, ${opacity})`;
    particle.style.animation = `float ${duration}s infinite ease-in-out ${delay}s`;

    container.appendChild(particle);
  }
</script>
