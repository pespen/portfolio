---

---

<section
  id="home"
  class="min-h-screen w-full flex flex-col justify-center items-center relative"
>
  <!-- Content -->
  <div class="z-10 text-center px-4 max-w-4xl mx-auto">
    <h1
      class="text-5xl md:text-7xl font-bold mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-500 to-purple-600"
    >
      Hello, I'm Peder
    </h1>
    <p class="text-2xl md:text-3xl text-gray-700 mb-8">
      I'm a Full Stack Developer
    </p>
    <p
      class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed"
    >
      I enjoy developing and using code to solve business problems.
    </p>

    <!-- Scroll indicator -->
    <a
      href="#about"
      class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce cursor-pointer hover:text-blue-500 transition-colors duration-300"
      aria-label="Scroll to About section"
    >
      <svg
        width="24"
        height="24"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        class="text-gray-500 hover:text-blue-500 transition-colors duration-300"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>
