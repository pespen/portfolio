---
import ProjectCard from './ProjectCard.astro';

interface Project {
  title: string;
  description: string;
  tags: string[];
  image?: string;
  liveUrl?: string;
  sourceUrl?: string;
}

interface Props {
  projects?: Project[];
  title?: string;
  description?: string;
}

const { 
  projects = [
    {
      title: "Project Name",
      description: "A brief description of the project and what technologies were used.",
      tags: ["React", "Node.js", "MongoDB"],
      liveUrl: "#",
      sourceUrl: "#"
    },
    {
      title: "Project Name",
      description: "A brief description of the project and what technologies were used.",
      tags: ["Vue", "Express", "PostgreSQL"],
      liveUrl: "#",
      sourceUrl: "#"
    },
    {
      title: "Project Name",
      description: "A brief description of the project and what technologies were used.",
      tags: ["Astro", "Tailwind", "Firebase"],
      liveUrl: "#",
      sourceUrl: "#"
    }
  ],
  title = "My Projects",
  description = "Here are some of the projects I've worked on."
} = Astro.props;
---

<section id="projects" class="py-20 scroll-mt-24">
  <h2 class="text-3xl font-bold text-center mb-4">{title}</h2>
  <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">
    {description}
  </p>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project) => (
      <ProjectCard 
        title={project.title}
        description={project.description}
        tags={project.tags}
        image={project.image}
        liveUrl={project.liveUrl}
        sourceUrl={project.sourceUrl}
      />
    ))}
  </div>
</section> 